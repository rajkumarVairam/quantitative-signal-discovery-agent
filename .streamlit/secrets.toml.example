# Copy this file to .streamlit/secrets.toml and fill in real values.
# NEVER commit secrets.toml — it is gitignored.
#
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Create an App Password for "Mail" and paste it below

SMTP_EMAIL    = "you@gmail.com"
SMTP_PASSWORD = "xxxx xxxx xxxx xxxx"   # 16-char Gmail App Password
SMTP_HOST     = "smtp.gmail.com"         # default, change for other providers
SMTP_PORT     = 587

# List of email addresses allowed to log in
ALLOWED_EMAILS = [
    "you@example.com",
    "colleague@example.com",
]
